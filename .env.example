# ── LLM 配置（DeepSeek 默认） ──────────────────────────────────────────────────
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Ollama 本地模型（免费，零成本） ──────────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# ── Claude 备用（V5 新增） ──────────────────────────────────────────────────────
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-xxx
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── GPT-4o 备用（V5 新增） ──────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

# ── LLM 自动降级（V5 新增） ────────────────────────────────────────────────────
# 当主 Provider 失败时，自动切换到备用（逗号分隔，按优先级排列）
# LLM_FALLBACK_CHAIN=deepseek,claude,openai

# ── 各 Agent 可单独覆盖模型（可选） ───────────────────────────────────────────
# ARCHITECT_MODEL=deepseek-chat
# WRITER_MODEL=deepseek-chat
# AUDITOR_MODEL=deepseek-reasoner   # 审计用推理模型效果更好
# REVISER_MODEL=deepseek-chat

# ── 写作参数 ───────────────────────────────────────────────────────────────────
DEFAULT_WORDS_PER_CHAPTER=4000
DEFAULT_TEMPERATURE=0.7
AUDITOR_TEMPERATURE=0.0             # 审计员锁温度 0，结果稳定

# ── 选择性审查模式（V5 新增） ──────────────────────────────────────────────────
# all=每章跑全部审查（默认）  light=只跑对话+场景  minimal=只跑审计  adaptive=按风险自适应
# PIPELINE_REVIEW_MODE=all
# 自适应模式下，每N章强制跑一次全量审查
# PIPELINE_REVIEW_FULL_INTERVAL=5
# 章节审计分低于此值触发全量审查（即使在 light/minimal 模式）
# PIPELINE_REVIEW_FORCE_SCORE=70

# ── WebSocket 实时进度（V5 新增） ──────────────────────────────────────────────
# WEBSOCKET_ENABLED=true

# ── 项目根目录 ─────────────────────────────────────────────────────────────────
BOOKS_DIR=./books
